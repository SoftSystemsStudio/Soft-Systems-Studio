# Local env for apps/agent-api
# For docker compose development use POSTGRES_URL pointing to the db service

POSTGRES_URL=postgresql://postgres:password@db:5432/softsystems
NODE_ENV=development
PORT=5000

# OpenAI key used by core-llm
OPENAI_API_KEY=sk-REPLACE_ME

# Optional integrations
SENDGRID_API_KEY=SG-REPLACE_ME
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Appended from .env.example on 2025-11-29T00:05:16.369Z
DATABASE_URL=${POSTGRES_URL}
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=default
JWT_SECRET=replace-with-secure-random-value
JWT_ALGORITHM=HS256
